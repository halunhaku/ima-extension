{
  "name": "web-clipper-for-ima",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc --noEmit && vite build",
    "validate": "node scripts/validate-release.mjs",
    "package": "npm run validate && npm run build && node scripts/package-release.mjs",
    "release:zip": "npm run package",
    "cws:publish": "node scripts/cws-publish.mjs",
    "cws:auth": "node scripts/cws-auth.mjs",
    "test": "npm run test:unit && npm run test:scripts",
    "test:unit": "vitest run",
    "test:scripts": "node --test scripts/package-release.test.mjs scripts/release-version.test.mjs scripts/cws-api.test.mjs scripts/cws-publish.test.mjs scripts/cws-auth.test.mjs scripts/release-workflow.test.mjs",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "dompurify": "^3.4.11",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "turndown": "^7.2.0",
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@types/turndown": "^5.0.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^4.1.9"
  }
}
